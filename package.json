{
  "name": "supershop",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:e2e": "pnpm --filter @supershop/api test:e2e",
    "migrate:up": "pnpm --filter @supershop/api migrate:up",
    "migrate:down": "pnpm --filter @supershop/api migrate:down",
    "migrate:status": "pnpm --filter @supershop/api migrate:status",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "devDependencies": {
    "turbo": "^2",
    "prettier": "^3",
    "husky": "^9",
    "lint-staged": "^17",
    "typescript": "^5"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs,json,md,css,yml,yaml}": "prettier --write"
  }
}

auto-install-peers=true
strict-peer-dependencies=false

# Supply-chain hardening: wait 7 days before resolving newly published versions
# (npm equivalent of pnpm's minimumReleaseAge in pnpm-workspace.yaml).
min-release-age=7

# Don't auto-run `pnpm install` before every command. The deps-status pre-check
# otherwise hard-fails on optional, prebuilt native deps whose postinstall we skip.
verify-deps-before-run=false
